{
  "build": {
    "command": "npm run build",
    "output_directory": "dist",
    "environment": {
      "NODE_VERSION": "20"
    }
  },
  "routes": [
    { "pattern": "/assets/*", "path": "/assets" },
    { "pattern": "/*", "path": "/index.html", "status": 200 }
  ],
  "headers": {
    "/": {
      "Cache-Control": "public, max-age=0, must-revalidate"
    },
    "/assets/*": {
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  }
}
